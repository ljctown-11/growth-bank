classDiagram
  class AppState {
    +daily: object
    +reviews: WeekReview[]
    +children: object[]
    +activeChildId: string
  }
  class WeekReview {
    +weekKey: string
    +weekIndex: number
    +dateRange: string
    +best: string
    +hard: string
    +next: string
    +parent: string
    +support: string
    +mood: string
  }
  class DayTask {
    +done: boolean
    +pts: number
    +cat: string
    +title: string
    +fromIdea: boolean
  }
  class IdeaLibrary {
    +id: string
    +title: string
    +pts: number
    +cat: string
  }
  class ModalManager {
    -registry: Map~string,HTMLElement~
    +openModal(id, builder, opts): HTMLElement
    +closeModal(id): void
  }
  class PasswordModal {
    +showPasswordModal(prompt, cb, onCancel): Promise~boolean~
  }
  AppState "1" *-- "0..*" WeekReview : reviews
  AppState "1" *-- "0..*" DayTask : daily[date].tasks
  ModalManager ..> PasswordModal : z1500 小于 z2000
  ideas.js ..> ModalManager : openModal('idea-library')
  render.js ..> ModalManager : openModal('review-detail'|'work-detail')
